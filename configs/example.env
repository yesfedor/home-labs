# --- Environment Type ---
ENV_TYPE=prod

# --- Database Credentials (Postgres) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=postgres

# --- Database Credentials (MariaDB/MySQL for NPM & Nextcloud) ---
MYSQL_ROOT_PASSWORD=change_me_secure_root_password
MYSQL_USER=npm
MYSQL_PASSWORD=change_me_secure_npm_password
MYSQL_DATABASE=npm
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=change_me_secure_nextcloud_password
NEXTCLOUD_DB_NAME=nextcloud

# --- Redis ---
REDIS_PASSWORD=change_me_secure_redis_password

# --- Beszel (Monitoring) ---
BESZEL_AGENT_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEHPrytCnNipp/vp7REoHDqGO1ZPqX6ruAfRtPBH1l74
BESZEL_AGENT_TOKEN=change_me_secure_token
BESZEL_HUB_URL=https://sys.example.com
BESZEL_AGENT_LISTEN=45876

# --- Docmost ---
DOCMOST_APP_URL=https://docs.example.com
DOCMOST_APP_SECRET=change_me_secure_secret
DOCMOST_DB_URL=postgresql://docmost:change_me_secure_docmost_password@db:5432/docmost?schema=public
DOCMOST_REDIS_URL=redis://redis:6379

# --- GitLab ---
GITLAB_HOSTNAME=git.example.com
GITLAB_REGISTRY_HOSTNAME=registry.git.example.com
GITLAB_ROOT_PASSWORD=change_me_secure_gitlab_root_password
GITLAB_RUNNER_TOKEN=change_me_secure_runner_token
GITLAB_URL=https://git.example.com

# --- GitLab SMTP ---
GITLAB_SMTP_ADDRESS=smtp.example.com
GITLAB_SMTP_PORT=465
GITLAB_SMTP_USER=no-reply@example.com
GITLAB_SMTP_PASSWORD=change_me_secure_smtp_password
GITLAB_SMTP_DOMAIN=example.com
GITLAB_EMAIL_FROM=no-reply@example.com
GITLAB_EMAIL_REPLY_TO=no-reply@example.com

# --- MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_secure_minio_password
MINIO_CONSOLE_ADDRESS=:9001

# --- Nextcloud ---
NEXTCLOUD_TRUSTED_DOMAINS=cloud.example.com
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_secure_nextcloud_admin_password

# --- Nginx Proxy Manager ---
NPM_DB_USER=npm
NPM_DB_PASSWORD=change_me_secure_npm_password
NPM_DB_NAME=npm

# --- Teleport ---
TELEPORT_AUTH_TOKEN=change_me_secure_teleport_token

# --- WireGuard ---
WG_HOST=vpn.example.com
WG_PASSWORD=change_me_secure_wg_password

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_secure_pgadmin_password
